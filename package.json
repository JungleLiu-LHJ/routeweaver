{
  "name": "hermes-router",
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone channel router for Hermes, OpenClaw, ACP, and custom agent backends.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "clawbot:demo": "tsx src/channels/clawbot/demo.ts",
    "test": "vitest run --dir test",
    "check": "npm run build && npm run test"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@tencent-weixin/openclaw-weixin": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.6.1",
    "pino": "^9.9.5",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
